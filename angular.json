{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "desktop": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/desktop",
      "sourceRoot": "projects/desktop/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/desktop",
            "index": "projects/desktop/src/index.html",
            "main": "projects/desktop/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/desktop/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "robots.txt",
                "input": "resources/files",
                "output": "/"
              },
              {
                "glob": "sitemap.xml",
                "input": "resources/files",
                "output": "/"
              },
              {
                "glob": "yandex_a33bf5848b3b53b6.html",
                "input": "resources/files",
                "output": "/"
              },
              {
                "glob": "*",
                "input": "resources/favicon",
                "output": "/"
              },
              "projects/desktop/src/assets"
            ],
            "styles": [
              "projects/desktop/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kb",
                  "maximumError": "1mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "browserTarget": "desktop:build:production"
            },
            "development": {
              "browserTarget": "desktop:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "desktop:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "projects/desktop/tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/desktop/src/favicon.ico",
              "projects/desktop/src/assets"
            ],
            "styles": [
              "projects/desktop/src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    }
  }
}
